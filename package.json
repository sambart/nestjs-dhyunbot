{
  "name": "nest-dhyunbot-monorepo",
  "version": "1.7.0",
  "description": "Discord bot monorepo with NestJS API and Next.js Web",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "api:dev": "npm run start:dev --workspace=@dhyunbot/api",
    "api:build": "npm run build --workspace=@dhyunbot/api",
    "api:start": "npm run start --workspace=@dhyunbot/api",
    "api:start:prod": "npm run start:prod --workspace=@dhyunbot/api",
    "api:test": "npm run test --workspace=@dhyunbot/api",
    "api:test:e2e": "npm run test:e2e --workspace=@dhyunbot/api",
    "web:dev": "npm run dev --workspace=@dhyunbot/web",
    "web:build": "npm run build --workspace=@dhyunbot/web",
    "web:start": "npm run start --workspace=@dhyunbot/web",
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write \"apps/*/src/**/*.{ts,tsx}\" \"libs/*/src/**/*.ts\"",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format:check": "prettier --check \"apps/*/src/**/*.{ts,tsx}\" \"libs/*/src/**/*.ts\"",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "postinstall": "npm run postinstall --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.50.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  }
}
